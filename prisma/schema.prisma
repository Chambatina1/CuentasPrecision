generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id              String   @id @default(cuid())
  name            String
  businessType    String
  activityType    String
  taxRegime       String
  nif             String?
  address         String?
  phone           String?
  email           String?
  currency        String   @default("CUP")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  transactions    Transaction[]
  taxDeclarations TaxDeclaration[]
}

model Transaction {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  type            String
  category        String
  subcategory     String?
  description     String
  amountCUP       Float
  amountUSD       Float?
  exchangeRate    Float?
  date            DateTime
  referenceNumber String?
  taxDeductible  Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TaxRate {
  id            String    @id @default(cuid())
  name          String
  code          String
  description   String
  rate          Float
  minValue      Float?
  maxValue      Float?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  gacetaRef     String?
  category      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TaxDeclaration {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])
  taxType       String
  periodStart   DateTime
  periodEnd     DateTime
  taxableIncome Float
  taxRate       Float
  taxAmount     Float
  deductions    Float     @default(0)
  netTax        Float
  status        String    @default("PENDIENTE")
  dueDate       DateTime
  paidDate      DateTime?
  gacetaRef     String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ExchangeRate {
  id        String   @id @default(cuid())
  source    String
  rateUSD   Float
  rateEUR   Float?
  rateMLC   Float?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model Alert {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  severity  String    @default("INFO")
  actionUrl String?
  isRead    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}
